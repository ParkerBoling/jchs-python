# rps game

# input
# r p or s
# process
# generate random num 1-3
# assign that num to rps
# check winner
# output
# user input
# computer input
# winner

# user inputs rock, computer chooses paper, computer wins.

import random

rock = 1
paper = 2
scissors = 3

def displayWinner(uChoice, cChoice):
    # display user and computer choices
    print("You chose: ", uChoice)
    
    if cChoice == rock:
        print("Computer chose: rock")
    elif cChoice == paper:
        print("Computer chose: paper")
    else:
        print("Computer chose: scissors")
    # display who wins    
    if (uChoice == "rock" and cChoice == scissors) or \
    (uChoice == "paper" and cChoice == rock) or \
    (uChoice == "scissors" and cChoice == paper):
        print("User wins!")
    elif (uChoice == "rock" and cChoice == paper) or \
         (uChoice == "paper" and cChoice == scissors) or \
         (uChoice == "scissors" and cChoice == rock):
        print("Computer wins!")
    else:
        print("Its a tie!")
def getUserChoice():
    choice = input("Enter Rock, Paper, or Scissors: ").lower()
    while choice != "rock" and choice != "paper" and choice != "scissors":
        print("Not a valid answer. Please pick again!")
        choice = input("Enter Rock, Paper, or Scissors: ").lower()
    return choice
        
def main():
    # get user/comp choices and run code
    userChoice = getUserChoice()
    computerChoice = random.randint(1, 3)
    displayWinner(userChoice, computerChoice)
    
if __name__ == "__main__":
    main()

