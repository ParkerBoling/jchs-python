# IN
# number
# PROC
# calculate if a perf num
# OUT
# true/false

def isPerfect(num):
    # goes through factors and adds them up so see if it equals num
    addedDivisors = 0
    for i in range(1, num):
        if num % i == 0:
            addedDivisors += i
    return addedDivisors == num

def main():
    number = int(input("Please input a number and see if it is perfect: "))
    if number < 1000 and number > 1:
        if isPerfect(number) == True:
            print("Your number is perfect!")
        else:
            print("Your number isnt perfect.")
    else:
        print("please enter a number between 1 and 1000.")
        
if __name__ == "__main__":
    main()
