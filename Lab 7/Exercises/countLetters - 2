# INPUT #
'''
words
letter
'''
# PROCESS #
'''
for char in words
look for letter
count + 1
'''
# OUTPUT #
'''
count of letter
'''

def letterCounter(words, letter):
    count = 0
    for word in words:
        count += word.count(letter.lower())
    return count

def main():
    sentence = input("Enter a sentence: ")
    letter = input("Enter the letter you are looking for: ")
    words = sentence.split()
    print(words)

    letterCount = letterCounter(words, letter)

    print("There are", letterCount, letter.upper() + "'s in your sentence")

if __name__ == "__main__":
    main()