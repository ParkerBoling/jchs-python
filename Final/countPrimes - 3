# countPrimes.py
# Function to count prime numbers in a list using an isPrime helper.


def isPrime(num):
    """Return True if num is a prime number, False otherwise."""
    if num <= 1:
        return False
    # only need to try factors up to square root
    for i in range(2, int(num**0.5) + 1):
        if num % i == 0:
            return False
    return True


def countPrimes(numbers):
    """Count how many items in the iterable `numbers` are prime."""
    total = 0
    for value in numbers:
        if isPrime(value):
            total += 1
    return total


def main():
    # initializer list of integers to test
    data = [1, 2, 3, 4, 5, 16, 17, 19, 20, 23]
    print(f"input list: {data}")
    primes = countPrimes(data)
    print(f"number of primes in list: {primes}")


if __name__ == "__main__":
    main()
